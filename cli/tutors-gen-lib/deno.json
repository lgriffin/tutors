{
  "name": "@tutors/tutors-gen-lib",
  "version": "4.2.12",
  "exports": "./src/tutors.ts",
  "license": "MIT",
  "tasks": {
    "test": "deno test ../test/unit/*.test.ts ../test/integration/*.test.ts --allow-all",
    "test:unit": "deno test ../test/unit/*.test.ts --allow-all",
    "test:integration": "deno test ../test/integration/*.test.ts --allow-all",
    "test:cli": "deno test ../test/integration/cli-execution.test.ts --allow-all",
    "test:reference": "deno test ../test/integration/reference-courses.test.ts --allow-all",
    "test:coverage": "deno test ../test/unit/*.test.ts ../test/integration/*.test.ts --coverage=coverage --allow-all && deno coverage coverage",
    "test:coverage:html": "deno test ../test/unit/*.test.ts ../test/integration/*.test.ts --coverage=coverage --allow-all && deno coverage coverage --html"
  },
  "imports": {
    "@tutors/tutors-model-lib": "jsr:@tutors/tutors-model-lib@^4",
    "front-matter": "npm:front-matter@^4.0.2",
    "js-yaml": "npm:js-yaml@^4.1.0",
    "archiver": "npm:archiver@^7.0.1",
    "@vento/vento": "jsr:@vento/vento@^1.14.0"
  }
}
